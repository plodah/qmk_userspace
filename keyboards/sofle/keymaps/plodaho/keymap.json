            "extrakey": true,
            "key_override": false,
            "leader": true,
            "mousekey": true,
            "oled": true,
            "os_detection": true,
            "pointing_device": false,
            "quantum_painter": false,
            "repeat_key": true,
            "rgblight": false,
            "rgb_matrix": true,
            "space_cadet": false,
            "swap_hands": true,
            "tap_dance": true,
            "tri_layer": true,
            "unicode": false,
