        },
        "tapping": {
            "chordal_hold": true,
            "flow_tap_term": 100,
            "permissive_hold": false,
            "speculative_hold": true,
            "term": 180,
            "toggle": 3
        },
        "usb": {
            "shared_endpoint": {
                "keyboard": true
            }
        }
